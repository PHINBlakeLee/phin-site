{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "src/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard|Inter))/i]",
        "message": "Font not provided by the design system. Available: Pretendard, Inter."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-soft",
      "--bg",
      "--bg-elev-1",
      "--bg-elev-2",
      "--bg-overlay",
      "--brand",
      "--brand-bright",
      "--brand-glow",
      "--brand-mute",
      "--brand-strong",
      "--champagne",
      "--dur-base",
      "--dur-fast",
      "--dur-slow",
      "--ease",
      "--font-body",
      "--font-display",
      "--font-numeric",
      "--ink-hi",
      "--ink-lo",
      "--ink-mid",
      "--ink-xlo",
      "--line",
      "--line-strong",
      "--negative",
      "--positive",
      "--r-2xl",
      "--r-lg",
      "--r-md",
      "--r-pill",
      "--r-sm",
      "--r-xl",
      "--space-2xl",
      "--space-3xl",
      "--space-4xl",
      "--space-5xl",
      "--space-lg",
      "--space-md",
      "--space-sm",
      "--space-xl",
      "--space-xs",
      "--space-xxs",
      "--tier-blue",
      "--tier-color",
      "--tier-gray",
      "--tier-green",
      "--tier-red",
      "--tier-yellow",
      "--type-body",
      "--type-body-lg",
      "--type-body-sm",
      "--type-caption",
      "--type-display-lg",
      "--type-display-md",
      "--type-display-sm",
      "--type-display-xl",
      "--type-h1",
      "--type-h2",
      "--type-hero",
      "--type-micro",
      "--warning"
    ],
    "tokenKinds": {
      "--bg": "color",
      "--bg-elev-1": "shadow",
      "--bg-elev-2": "shadow",
      "--bg-overlay": "color",
      "--brand": "color",
      "--brand-strong": "color",
